{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": ["/tmp"]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "codeload.github.com",
        "api.linear.app",
        "*.anthropic.com",
        "code.claude.com",
        "docs.claude.com",
        "docs.anthropic.com",
        "registry.npmjs.org",
        "*.npmjs.org",
        "registry.yarnpkg.com"
      ]
    }
  }
}
